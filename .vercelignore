# Vercel deploy excludes — keep non-deploy / local-only assets out of uploads.
# Secrets (also gitignored; listed here as defense-in-depth)
.env
.env.*
!.env.example
.mcp.json

# Local agent / editor state
.claude/
.codex/
.vscode/
.idea/

# Heavy source material and local-only tooling (not served by the app)
artifacts/
local-archive/
scripts/
public/demo-product-video.html

# Archives
*.zip
*.tar
*.tar.gz
*.tgz

# OS noise
.DS_Store
