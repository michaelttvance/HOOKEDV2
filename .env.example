# Twilio — outbound status SMS only (job assigned / on-scene / complete notifications to customers)
# These power the three SMS sends in dispatch-store.tsx via sms.functions.ts.
# Missing vars cause SMS sends to fail silently — job operations continue normally.
# TWILIO_PHONE_NUMBER must be E.164 format, e.g. +15551234567.
# Do NOT commit real Twilio secrets; keep them in Vercel environment variables only.
# Note: inbound voice/SMS webhook recovery (twilio-voice, twilio-sms routes) is NOT
# launch-ready and requires additional DB schema work before enabling — see open-decisions.md.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
